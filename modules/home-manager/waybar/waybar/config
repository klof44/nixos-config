{
    "modules-left": ["hyprland/workspaces", "custom/media"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "pulseaudio", "backlight", "temperature", "battery"],
    "output": ["eDP-1", "eDP-2"],
    
    "custom/media": {
      "return-type": "json",
      "exec": "sh ~/.config/waybar/scripts/music.sh",
      "on-click": "playerctl --player=%any,firefox play-pause",
      "on-scroll-up": "playerctl --player=%any,firefox next",
      "on-scroll-down": "playerctl --player=%any,firefox previous"
    },

    "network": {
        "format-wifi": "ΎΘτ",
        "format-ethernet": "{ifname} ΎΔΒ",
        "format-disconnected": "ΎΔΒ", 
        "max-length": 50,
        "on-click": "foot -e 'nmtui-connect'"
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10,
        "layer": "top"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "0% {icon} ",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
	"custom/power": {
		"format": "ΎΑΣ ",
		"on-click": "bash $HOME/.config/rofi/powermenu.sh"
	},
  "battery": {
    "interval": 10,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░Β╣"],
    "format-full": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "tooltip": false
  },
  "backlight": {
    "device": "intel_backlight",
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1",
    "format": "{icon} {percent}%",
    "format-icons": ["≤░Δη","≤░Δθ","≤░Δζ","≤░Δι"]
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
    "critical-threshold": 65,
    "tooltip": false,
    "format": "ΎΤ╝ {temperatureC}┬░C"
  }
}